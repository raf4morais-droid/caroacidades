# Example env for Terraform TF_VARs — copy to .env and fill secrets.
# DO NOT commit the resulting .env file. This file is safe to keep in repo.

# Postgres password for Cloud SQL
TF_VAR_db_password=your_postgres_password_here

# Firebase service account JSON, base64-encoded, single line
# How to create: cat /path/to/sa.json | base64 | tr -d '\n'
TF_VAR_firebase_service_account=BASE64_ENCODED_SERVICE_ACCOUNT_JSON
