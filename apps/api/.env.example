NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# PostgreSQL (Cloud SQL via Auth Proxy em produção, local em dev)
DATABASE_URL=postgresql://sigweb:password@localhost:5432/sigweb

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"sigweb-tupancireta",...}
FIREBASE_STORAGE_BUCKET=sigweb-tupancireta.appspot.com

# CORS
CORS_ORIGIN=http://localhost:5173,https://sigweb.tupancireta.rs.gov.br

# Cadastro Social — chave simétrica (pgcrypto pgp_sym_*) para criptografar CPF/NIS/PIS (req 88)
SOCIAL_ENC_KEY=troque-esta-chave-em-producao

# Senha de confirmação para "Apagar banco de dados" (Painel Dev → Gestão do SIG).
# Validada apenas no backend; a rota é bloqueada quando NODE_ENV=production.
DEV_WIPE_PASSWORD=
