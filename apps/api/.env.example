NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# PostgreSQL (Cloud SQL via Auth Proxy em produção, local em dev)
DATABASE_URL=postgresql://sigweb:password@localhost:5432/sigweb

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"sigweb-tupancireta",...}
FIREBASE_STORAGE_BUCKET=sigweb-tupancireta.appspot.com

# CORS
CORS_ORIGIN=http://localhost:5173,https://sigweb.tupancireta.rs.gov.br
